<div class="cart-page page-content">
  <h1>{{ 'cart.title' | t }}</h1>

  {% if cart.item_count == 0 %}
    <p class="text-muted">{{ 'cart.empty' | t }}</p>
    <a class="btn btn-primary" href="{{ routes.all_products_collection_url }}" style="margin-top: 1rem;">
      {{ 'cart.continue_shopping' | t }}
    </a>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post">
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item card">
            <div class="cart-item__media">
              {% if item.image %}
                <a href="{{ item.url }}">
                  {{ item.image | image_url: width: 200, height: 200, crop: 'center' | image_tag: loading: 'lazy' }}
                </a>
              {% endif %}
            </div>

            <div class="cart-item__details">
              <p class="cart-item__title">
                <a href="{{ item.url }}">{{ item.product.title }}</a>
              </p>
              {% if item.variant.title != 'Default Title' %}
                <p class="cart-item__variant text-sm text-muted">{{ item.variant.title }}</p>
              {% endif %}
              <p class="cart-item__price text-sm">{{ item.price | money }}</p>
            </div>

            <div class="cart-item__actions">
              <input
                type="number"
                name="updates[]"
                value="{{ item.quantity }}"
                min="0"
                aria-label="{{ 'products.quantity' | t }}"
                style="width: 4rem; text-align: center;"
              >
              <a href="{{ item.url_to_remove }}" class="cart-item__remove text-sm text-muted">
                {{ 'cart.remove' | t }}
              </a>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="cart-footer">
        <button type="submit" class="btn btn-secondary">{{ 'cart.update' | t }}</button>
        <div class="cart-footer__total">
          <p>{{ 'cart.total' | t }}: <strong>{{ cart.total_price | money }}</strong></p>
          <button type="submit" name="checkout" class="btn btn-primary btn-lg">{{ 'cart.checkout' | t }}</button>
        </div>
      </div>
    </form>
  {% endif %}
</div>

{% stylesheet %}
  .cart-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .cart-item {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    align-items: flex-start;
  }

  .cart-item__media {
    flex-shrink: 0;
    width: 5rem;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background-color: var(--color-bg-secondary);
  }

  .cart-item__media img {
    width: 100%;
    height: auto;
  }

  .cart-item__details {
    flex: 1;
    min-width: 0;
  }

  .cart-item__title a {
    font-weight: 500;
    text-decoration: none;
  }

  .cart-item__title a:hover {
    text-decoration: underline;
  }

  .cart-item__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .cart-item__remove {
    text-decoration: none;
  }

  .cart-item__remove:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .cart-footer {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }

  .cart-footer__total {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    font-size: 1.125rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
