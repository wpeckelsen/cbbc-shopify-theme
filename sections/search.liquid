<div class="search-page page-content">
  <h1>{{ 'search.title' | t }}</h1>

  <form class="search-form" action="{{ routes.search_url }}" method="get" role="search">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      class="search-form__input"
    >
    <button type="submit" class="btn btn-primary">{{ 'search.submit' | t }}</button>
  </form>

  {% if search.performed %}
    {% if search.results_count == 0 %}
      <p class="text-muted" style="margin-top: 1.5rem;">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
    {% else %}
      <p class="text-muted" style="margin-top: 1.5rem;">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

      {% paginate search.results by 20 %}
        <div class="search-results">
          {% for result in search.results %}
            <div class="search-result card">
              <a href="{{ result.url }}" class="search-result__link">
                {% assign featured_image = result.featured_image | default: result.image %}
                {% if featured_image %}
                  <div class="search-result__media">
                    {{ featured_image | image_url: width: 200, height: 200, crop: 'center' | image_tag: loading: 'lazy' }}
                  </div>
                {% endif %}
                <div class="search-result__info">
                  <p class="search-result__title">{{ result.title }}</p>
                  {% if result.price %}
                    <p class="search-result__price text-sm text-muted">{{ result.price | money }}</p>
                  {% endif %}
                </div>
              </a>
            </div>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    {% endif %}
  {% endif %}
</div>

{% stylesheet %}
  .search-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    max-width: 32rem;
  }

  .search-form__input {
    flex: 1;
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(14rem, 100%), 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .search-result__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .search-result__link:hover {
    text-decoration: none;
  }

  .search-result__media {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
  }

  .search-result__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-result__info {
    padding: 0.75rem 1rem 1rem;
  }

  .search-result__title {
    font-weight: 500;
    font-size: 0.875rem;
  }

  .search-result__price {
    margin-top: 0.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
