<div class="contact-page page-content">
  <h1>{{ 'contact.title' | t }}</h1>
  <p class="text-muted">{{ 'contact.description' | t }}</p>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="contact-success card" style="padding: 1rem; margin-top: 1.5rem; border-color: var(--color-accent);">
        <p>{{ 'contact.success' | t }}</p>
      </div>
    {% endif %}

    {{ form.errors | default_errors }}

    <div class="contact-form" style="margin-top: 1.5rem;">
      <div class="contact-form__field">
        <label for="contact-name">{{ 'contact.name' | t }}</label>
        <input type="text" id="contact-name" name="contact[name]" required>
      </div>

      <div class="contact-form__field">
        <label for="contact-email">{{ 'contact.email' | t }}</label>
        <input type="email" id="contact-email" name="contact[email]" required>
      </div>

      <div class="contact-form__field">
        <label for="contact-message">{{ 'contact.message' | t }}</label>
        <textarea id="contact-message" name="contact[body]" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary" style="margin-top: 0.25rem;">
        {{ 'contact.submit' | t }}
      </button>
    </div>
  {% endform %}
</div>

{% stylesheet %}
  .contact-form {
    max-width: 28rem;
  }

  .contact-form__field {
    margin-top: 1rem;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    width: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact.name",
  "settings": [],
  "presets": [
    {
      "name": "t:sections.contact.name"
    }
  ]
}
{% endschema %}
