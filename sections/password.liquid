<div class="password-page page-content" style="max-width: 24rem; margin: 0 auto; text-align: center; padding-top: 5rem;">
  <h1>{{ 'password.title' | t }}</h1>

  {% if shop.password_message %}
    <p class="text-muted" style="margin-top: 0.5rem;">{{ shop.password_message }}</p>
  {% endif %}

  {% form 'storefront_password' %}
    {% if form.errors %}
      <div style="margin-top: 1rem;">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div style="margin-top: 1.5rem; text-align: left;">
      <label for="password-input">{{ 'password.password' | t }}</label>
      <input type="password" name="password" id="password-input" style="width: 100%;">
    </div>

    <button type="submit" class="btn btn-primary" style="margin-top: 1rem; width: 100%;">
      {{ 'password.enter' | t }}
    </button>
  {% endform %}
</div>

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
