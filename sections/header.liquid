<header class="header">
  <div class="header__inner">
    <a class="header__logo" href="{{ routes.root_url }}">
      <img
        src="{{ 'cbbcinc.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="120"
        height="48"
        loading="eager"
      >
    </a>

    <nav class="header__nav" aria-label="{{ 'general.navigation' | t }}">
      {% for link in section.settings.menu.links %}
        <a
          class="header__nav-link{% if link.active %} header__nav-link--active{% endif %}"
          href="{{ link.url }}"
        >
          {{- link.title -}}
        </a>
      {% endfor %}
    </nav>

    <div class="header__actions">
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" class="header__action" aria-label="{{ 'general.account' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </a>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="header__action header__cart" aria-label="{{ 'cart.title' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>

    <button class="header__mobile-toggle" aria-label="{{ 'general.menu' | t }}" aria-expanded="false">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" class="header__hamburger-top"></line>
        <line x1="3" y1="12" x2="21" y2="12" class="header__hamburger-mid"></line>
        <line x1="3" y1="18" x2="21" y2="18" class="header__hamburger-bot"></line>
      </svg>
    </button>
  </div>

  <nav class="header__mobile-nav" aria-label="{{ 'general.navigation' | t }}">
    {% for link in section.settings.menu.links %}
      <a
        class="header__mobile-link{% if link.active %} header__mobile-link--active{% endif %}"
        href="{{ link.url }}"
      >
        {{- link.title -}}
      </a>
    {% endfor %}
  </nav>
</header>

{% stylesheet %}
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  .header__logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .header__logo img {
    height: 2.5rem;
    width: auto;
  }

  .header__nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  .header__nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-fg-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .header__nav-link:hover {
    color: var(--color-fg);
    background-color: var(--color-bg-secondary);
    text-decoration: none;
  }

  .header__nav-link--active {
    color: var(--color-fg);
    font-weight: 600;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sm);
    color: var(--color-fg-muted);
    transition: color 0.15s ease, background-color 0.15s ease;
    text-decoration: none;
  }

  .header__action:hover {
    color: var(--color-fg);
    background-color: var(--color-bg-secondary);
    text-decoration: none;
  }

  .header__action svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .header__cart {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: 0;
    right: 0;
    min-width: 1rem;
    height: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
    background-color: var(--color-accent);
    color: var(--color-accent-fg);
    border-radius: 999px;
    padding: 0 0.25rem;
  }

  .header__mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: none;
    background: none;
    color: var(--color-fg);
    cursor: pointer;
    border-radius: var(--radius-sm);
  }

  .header__mobile-toggle:hover {
    background-color: var(--color-bg-secondary);
  }

  .header__mobile-nav {
    display: none;
    flex-direction: column;
    padding: 0.5rem var(--page-margin) 1rem;
    border-top: 1px solid var(--color-border);
  }

  .header__mobile-nav[data-open] {
    display: flex;
  }

  .header__mobile-link {
    padding: 0.75rem 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-fg-muted);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
  }

  .header__mobile-link:hover {
    color: var(--color-fg);
    text-decoration: none;
  }

  .header__mobile-link--active {
    color: var(--color-accent);
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
    .header__mobile-toggle {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var toggle = document.querySelector('.header__mobile-toggle');
    var nav = document.querySelector('.header__mobile-nav');
    if (!toggle || !nav) return;
    toggle.addEventListener('click', function () {
      var open = nav.hasAttribute('data-open');
      if (open) {
        nav.removeAttribute('data-open');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        nav.setAttribute('data-open', '');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
