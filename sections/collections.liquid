<div class="collections-page page-content">
  <h1>{{ 'collections.title' | t }}</h1>

  <div class="collections-grid" style="--gap: {{ section.settings.grid_gap }}px">
    {% for collection in collections %}
      <a class="collections-card card" href="{{ collection.url }}">
        {% if collection.featured_image %}
          <div class="collections-card__media">
            {{ collection.featured_image | image_url: width: 600, height: 600, crop: 'center' | image_tag: loading: 'lazy' }}
          </div>
        {% endif %}

        <div class="collections-card__info">
          <p class="collections-card__title">{{ collection.title }}</p>
          {% if collection.description != blank %}
            <p class="collections-card__desc text-muted text-sm">{{ collection.description | strip_html | truncatewords: 15 }}</p>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: var(--gap, 1rem);
    margin-top: 1.5rem;
  }

  .collections-card {
    text-decoration: none;
    color: inherit;
  }

  .collections-card:hover {
    text-decoration: none;
  }

  .collections-card__media {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: var(--color-bg-secondary);
  }

  .collections-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collections-card:hover .collections-card__media img {
    transform: scale(1.03);
  }

  .collections-card__info {
    padding: 0.75rem 1rem 1rem;
  }

  .collections-card__title {
    font-weight: 500;
  }

  .collections-card__desc {
    margin-top: 0.25rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [
    {
      "type": "range",
      "id": "grid_gap",
      "label": "t:labels.grid_gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [{ "name": "t:general.collections_grid" }]
}
{% endschema %}
