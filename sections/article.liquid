<div class="article-page page-content">
  {% if article.image %}
    <div class="article-page__hero">
      {{ article.image | image_url: width: 1400 | image_tag: loading: 'eager' }}
    </div>
  {% endif %}

  <div class="article-page__header">
    <h1>{{ article.title }}</h1>
    {% assign date = article.published_at | time_tag: format: 'date' %}
    <p class="text-sm text-muted">{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
  </div>

  <div class="article-page__body">
    {{ article.content }}
  </div>

  {% if blog.comments_enabled? %}
    <div class="article-comments">
      <h2>{{ 'blog.article_comments' | t }}</h2>

      {% paginate article.comments by 10 %}
        {% for comment in article.comments %}
          <div class="article-comment card" style="padding: 1rem; margin-top: 0.75rem;">
            <p class="text-sm"><strong>{{ comment.author }}</strong></p>
            <p class="text-sm text-muted">{{ comment.created_at | time_tag: format: 'date' }}</p>
            <p style="margin-top: 0.5rem;">{{ comment.content }}</p>
          </div>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="pagination">
            {{ paginate | default_pagination: anchor: 'comments' }}
          </div>
        {% endif %}
      {% endpaginate %}

      {% form 'new_comment', article %}
        <div class="article-comment-form" style="margin-top: 2rem;">
          <h2>{{ 'blog.comment_form_title' | t }}</h2>

          {{ form.errors | default_errors }}

          <div class="article-comment-form__field">
            <label for="author">{{ 'blog.comment_form_name' | t }}</label>
            <input type="text" name="comment[author]" id="author" value="{{ form.author }}" required>
          </div>

          <div class="article-comment-form__field">
            <label for="email">{{ 'blog.comment_form_email' | t }}</label>
            <input type="email" name="comment[email]" id="email" value="{{ form.email }}" required>
          </div>

          <div class="article-comment-form__field">
            <label for="body">{{ 'blog.comment_form_body' | t }}</label>
            <textarea name="comment[body]" id="body" required>{{ form.body }}</textarea>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top: 0.75rem;">
            {{ 'blog.comment_form_submit' | t }}
          </button>
        </div>
      {% endform %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .article-page__hero {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .article-page__hero img {
    width: 100%;
    height: auto;
    max-height: 28rem;
    object-fit: cover;
  }

  .article-page__header {
    margin-bottom: 1.5rem;
  }

  .article-page__body {
    max-width: 48rem;
    font-size: 1rem;
    line-height: 1.75;
  }

  .article-page__body img {
    border-radius: var(--radius-sm);
    margin: 1rem 0;
  }

  .article-comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .article-comment-form__field {
    margin-top: 0.75rem;
  }

  .article-comment-form__field input,
  .article-comment-form__field textarea {
    width: 100%;
    max-width: 28rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": []
}
{% endschema %}
