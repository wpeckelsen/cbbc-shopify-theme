<div class="featured-products section-spacing">
  {% if section.settings.heading != blank %}
    <h2 class="featured-products__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="featured-products__grid" style="--columns: {{ section.settings.columns }}">
    {% assign limit = section.settings.product_count %}
    {% assign count = 0 %}
    {% for product in collections.all.products %}
      {% if count >= limit %}
        {% break %}
      {% endif %}
      {% render 'product-card', product: product %}
      {% assign count = count | plus: 1 %}
    {% endfor %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="featured-products__action">
      <a class="btn btn-outline" href="{{ routes.all_products_collection_url }}">
        {{ section.settings.button_label }}
      </a>
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .featured-products__heading {
    margin-bottom: 1.5rem;
  }

  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .featured-products__action {
    margin-top: 2rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .featured-products__grid {
      grid-template-columns: repeat(var(--columns), 1fr);
      gap: 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_products.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_products.settings.heading",
      "default": "Featured products"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "t:sections.featured_products.settings.product_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:sections.featured_products.settings.columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.featured_products.settings.button_label",
      "default": "View all products"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_products.name"
    }
  ]
}
{% endschema %}
